# Doxen Output (regular runs)
.doxen/

# Experimental Framework - ignore ALL cloned repos (they're external dependencies)
experimental/projects/*/
!experimental/projects/*/*.json
!experimental/projects/*/ground_truth/
!experimental/projects/*/doxen_output/

# Archive of cloned repos - never commit these
experimental/projects-archive/

# Experimental results - ignore generated documentation (keep analysis files)
experimental/results/*/guides/
experimental/results/*/reference_docs/

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.coverage
htmlcov/
.tox/
.mypy_cache/
.dmypy.json
dmypy.json

# Virtual Environments
venv/
env/
ENV/
.venv

# Node.js (if using TypeScript/JavaScript)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
dist/
.next/
out/

# Rust (if using Rust)
target/
Cargo.lock
**/*.rs.bk

# Ruby (bundler)
vendor/bundle/
Gemfile.lock
.bundle/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Environment variables
.env
.env.local
.env.*.local
*.key
*.pem
secrets/

# Test outputs
test-output/
coverage/
*.log

# Temporary files
tmp/
temp/
*.tmp
